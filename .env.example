# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Minecraft server (default: localhost:25565)
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565

# Mineflayer HTTP bridge port (default: 3000)
MINEFLAYER_PORT=3000

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional: override control primitives path
# CONTROL_PRIMITIVES_PATH=/absolute/path/to/control_primitives_context
